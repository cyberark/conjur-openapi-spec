#!/usr/bin/env bash

if [ $1 = '--oss' ] || [ $1 = '' ]; then
    ./bin/transform --oss
    input_file=/code/out/conjur/spec/openapi.yml
elif [ $1 = '--dap' ]; then
    ./bin/transform --dap
    input_file=/code/out/dap/spec/openapi.yml
fi

docker run --rm \
    -v ${PWD}:/code \
    node:latest \
    /bin/bash -c "npm i -g @stoplight/spectral && npm i -g swagger-cli && swagger-cli bundle $input_file --outfile /code/spec.yml --type yaml"
