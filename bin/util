#!/usr/bin/env bash

function get_banner(){
  for word in $@
  do
    echo -n "+"
    for (( i=0; i<${#word}; i++ )) do
      echo -n "+"
    done
  done

  echo
}

function announce() {
  banner=$(get_banner $@)
  echo $banner
  echo "$@"
  echo $banner
}

function conjur_container_alive(){
  if [ -z `docker-compose ps -q conjur` ]; then
    echo 1
  elif [ -z `docker ps -q --no-trunc | grep $(docker-compose ps -q conjur)` ]; then
    echo 1
  else
    echo 0
  fi
}